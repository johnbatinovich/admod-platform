# ─── AdMod Platform Configuration ─────────────────────────────────────────
# Copy to .env and fill in values

# ─── Database ─────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, AWS RDS, local, etc.)
DATABASE_URL="postgresql://user:password@host:5432/admod"

# ─── Authentication ───────────────────────────────────────────────────────
# Secret for signing JWT session tokens (generate with: openssl rand -base64 32)
JWT_SECRET="change-me-to-a-random-64-char-string"

# Default admin email and password (created on first boot)
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="change-this-immediately"

# ─── LLM Provider ────────────────────────────────────────────────────────
# Supported: "openai" | "anthropic"
LLM_PROVIDER="openai"

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"          # For vision/frame analysis
OPENAI_TEXT_MODEL="gpt-4o"     # For text-only analysis

# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ─── Object Storage (S3-Compatible) ──────────────────────────────────────
# Works with AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces
S3_ENDPOINT="https://s3.us-east-1.amazonaws.com"   # or R2/MinIO endpoint
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="AKIA..."
S3_SECRET_ACCESS_KEY="..."
S3_BUCKET="admod-uploads"
S3_PUBLIC_URL=""  # Optional: CDN/public URL prefix for uploaded files

# ─── Frame Extraction ────────────────────────────────────────────────────
# Temp directory for frame extraction (must be writable)
FRAME_EXTRACT_DIR="/tmp/admod-frames"

# Max frames to extract per video (limits LLM token cost)
MAX_FRAMES_PER_VIDEO="120"

# Frame extraction quality (1-31, lower = better quality, bigger files)
FRAME_QUALITY="2"

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
